{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend-app1",
    "apps/frontend-app2"
  ],
  "scripts": {
    "dev:app1": "cd apps/frontend-app1 && npm run dev",
    "dev:app2": "cd apps/frontend-app2 && npm run dev",
    "build:app1": "cd apps/frontend-app1 && npm run build",
    "build:app2": "cd apps/frontend-app2 && npm run build"
  }
}
